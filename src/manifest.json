{
  "manifest_version": 3,
  "name": "Dictation Saver for ChatGPT",
  "version": "0.1",
  "description": "Keep a backup of your ChatGPT voice dictations.",
  "permissions": ["scripting", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"]
    }
  ]
}
