{
  "manifest_version": 3,
  "name": "Dictation Saver for ChatGPT",
  "version": "0.3.0",
  "description": "Keep a backup of your ChatGPT voice dictations.",
  "permissions": ["scripting", "activeTab", "storage"],
  "background": {
    "service_worker": "src/background.ts"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["src/content.ts"]
    }
  ]
}
